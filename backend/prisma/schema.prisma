// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ======================
// MODELO USUARIO (ACTUALIZADO)
// ======================

model Usuario {
  id        Int     @id @default(autoincrement())
  nombre    String
  apellido  String
  username  String  @unique
  password  String
  rol       String? // "CORTE", "ARMADO", "COSTURA", "SOLADURA", etc.
  
  cedula    String?
  telefono  String?
  activo    Boolean @default(true) 

  // Relaciones Generales
  clientes      Cliente[]
  ventas        Venta[]
  
  // --- HISTORIAL DE TRABAJO (NUEVO) ---
  // Prisma necesita saber qué relación es cuál
  ordenesCorte         OrdenProduccion[] @relation("OrdenCortador")
  ordenesArmado        OrdenProduccion[] @relation("OrdenArmador")
  ordenesCostura       OrdenProduccion[] @relation("OrdenCosturero")
  ordenesSoladura      OrdenProduccion[] @relation("OrdenSolador")
  ordenesEmplantillado OrdenProduccion[] @relation("OrdenEmplantillador")
}

model Cliente {
  id          Int      @id @default(autoincrement())
  nombre      String
  telefono    String?
  email       String?
  direccion   String?
  tipoCliente String   
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())

  vendedor    Usuario? @relation(fields: [vendedorId], references: [id])
  vendedorId  Int?

  ventas      Venta[]
  ordenes     OrdenProduccion[]
}

model Producto {
  id              Int      @id @default(autoincrement())
  nombreModelo    String
  descripcion     String?
  precioDetal     Float
  precioMayor     Float
  costoProduccion Float
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())

  stock           Stock[]
  detallesVenta   DetalleVenta[]
}

model Local {
  id        Int      @id @default(autoincrement())
  nombre    String
  direccion String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  stock     Stock[]
  ventas    Venta[]
}

model Stock {
  id               Int      @id @default(autoincrement())
  producto         Producto @relation(fields: [productoId], references: [id])
  productoId       Int
  talla            Int
  local            Local    @relation(fields: [localId], references: [id])
  localId          Int
  paresDisponibles Int
  updatedAt        DateTime @updatedAt

  @@unique([productoId, talla, localId])
}

//Tarifas por Categoría (Romana, Clasica, Zara)
model TarifaCategoria {
  id              Int    @id @default(autoincrement())
  nombre          String @unique // "ROMANA", "CLASICA", "ZARA"
  
  // PRECIOS POR CADA PROCESO
  precioCorte         Int @default(0)
  precioArmado        Int @default(0)
  precioCostura       Int @default(0)
  precioSoladura      Int @default(0)
  precioEmplantillado Int @default(0)
}


// ==========================================
// MÓDULO DE PRODUCCIÓN (COMPLETO)
// ==========================================

model OrdenProduccion {
  id          Int      @id @default(autoincrement())
  numeroOrden String   @unique 
  fechaInicio DateTime @default(now())
  // --- FECHAS DE FINALIZACIÓN POR ETAPA ---
  // Cuando estas fechas tengan valor, significa que el empleado ya cobró esa parte
  fechaFinCorte      DateTime? 
  fechaFinArmado     DateTime?
  fechaFinCostura   DateTime?  
  fechaFinSoladura   DateTime?
  fechaFinEmplantillado   DateTime?  
  fechaFinTerminado  DateTime? // Cuando sale de fábrica
  estado      String   @default("EN_CORTE") 
  
  // Detalle
  referencia  String 
  color       String  
  fotoUrl     String?  
  materiales  String   
  observacion String?  
  // (Romana, Clasica...)
  categoria   String   @default("ROMANA") 
  
  // --- PRECIOS CONGELADOS PARA ESTA ORDEN ---
  precioCorte         Int @default(0)
  precioArmado        Int @default(0)
  precioCostura       Int @default(0)
  precioSoladura      Int @default(0)
  precioEmplantillado Int @default(0)

  // Destino
  destino     String   // "CLIENTE" o "STOCK"
  cliente     Cliente? @relation(fields: [clienteId], references: [id])
  clienteId   Int?     

  // --- ASIGNACIÓN DE RESPONSABLES (LA LÍNEA DE FÁBRICA) ---
  
  // 1. Corte
  cortador          Usuario? @relation("OrdenCortador", fields: [cortadorId], references: [id])
  cortadorId        Int?

  // 2. Armado (Guarnición)
  armador           Usuario? @relation("OrdenArmador", fields: [armadorId], references: [id])
  armadorId         Int?

  // 3. Costura
  costurero         Usuario? @relation("OrdenCosturero", fields: [costureroId], references: [id])
  costureroId       Int?

  // 4. Soladura
  solador           Usuario? @relation("OrdenSolador", fields: [soladorId], references: [id])
  soladorId         Int?

  // 5. Emplantillado
  emplantillador    Usuario? @relation("OrdenEmplantillador", fields: [emplantilladorId], references: [id])
  emplantilladorId  Int?

  // La Curva
  t34 Int @default(0)
  t35 Int @default(0)
  t36 Int @default(0)
  t37 Int @default(0)
  t38 Int @default(0)
  t39 Int @default(0)
  t40 Int @default(0)
  t41 Int @default(0)
  t42 Int @default(0)
  t43 Int @default(0)
  t44 Int @default(0)

  totalPares Int 
}

model Venta {
  id         Int      @id @default(autoincrement())
  cliente    Cliente  @relation(fields: [clienteId], references: [id])
  clienteId  Int
  vendedor   Usuario  @relation(fields: [vendedorId], references: [id])
  vendedorId Int
  local      Local?   @relation(fields: [localId], references: [id])
  localId    Int?
  fechaVenta DateTime @default(now())
  total      Float
  metodoPago String

  detalles DetalleVenta[]
}

model DetalleVenta {
  id             Int      @id @default(autoincrement())
  venta          Venta    @relation(fields: [ventaId], references: [id])
  ventaId        Int
  producto       Producto @relation(fields: [productoId], references: [id])
  productoId     Int
  talla          Int
  cantidad       Int
  precioUnitario Float
}

model InventarioZapatos {
  id          Int      @id @default(autoincrement())
  referencia  String   
  color       String   
  sucursal    String   
  tipo        String   @default("PLANA")
  
  t35         Int      @default(0)
  t36         Int      @default(0)
  t37         Int      @default(0)
  t38         Int      @default(0)
  t39         Int      @default(0)
  t40         Int      @default(0)
  t41         Int      @default(0)
  t42         Int      @default(0)
  
  total       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([referencia, color, sucursal])
}